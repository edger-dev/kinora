entries ({id 7d55b69762759bc9b81c67ddf96f48027abcd9c06e2f89079ca5adc04a26039e, name store-content-addressed, pin "", note "Blobs are named by the hash of their bytes — the basis for dedup, integrity, and portable identity."} {id 2c86d78993802cdfc9c10c9c401685ec65be197f1a1a0d7ce7cca9d0968cd930, name hot-ledger-one-file-per-event, pin "", note "One file per event is what makes the ledger set-union mergeable across git branches."} {id 6ef18896e1bcdbf8ae99dd1e4ea542c466263eaf72e262647a431c52dda046d9, name event-envelope, pin "", note "Every event carries a fixed, canonical envelope — the shape agents and tools can rely on."} {id 0dab815061b18b30b4a40017e908b54f11ee3dd02f4fc81146c42b69da40c017, name identity-and-versions, pin "", note "Identity is stable across edits; versions link via parents. No HEAD pointer to contend over."} {id b0110a19a5531e11d3be06622f70563e8beb2571abcc68a2f9a69f5105442a03, name kinograph-composition-by-reference, pin "", note "Kinographs compose kinos by id, not by copying content."} {id 4f5286e153510fe5156b75927a546793bcd9b182b19966e9151c9b12cbf0da73, name name-vs-id, pin "", note "Ids are authoritative; names are hints. Ambiguity surfaces loudly rather than silently."} {id 1c8bb6ce9b692845cddfde11b8f775b73c7acb59992ecd7d5fa92f00b873fa46, name provenance-mandatory, pin "", note "Every event records where the content came from — structural, not stylistic."} {id b2d2c296f93276f1efa2de06f4930b63318e463e9c220290059fa84612abd08f, name metadata-namespaces, pin "", note "Core keys are reserved; extensions live under `prefix::`."} {id 684003b00dc6ec3710d75cc50decf339a1498bf7752118ccd1845a6b356b2ca4, name branch-merge-safety, pin "", note "No filename encodes branch identity — merges are conflict-free by construction."} {id b66729af0763395fba473f52a0e8aee1cdcc05cf31a7215daab2059aaf19e45d, name append-only-nothing-mutates, pin "", note "Edits create new versions; nothing on disk is ever rewritten."} {id 291e854c0bad0a49a1032fc86f20c7e871b20dbb8eddf5d9bb6ab092013c904f, name future-root-kinograph-chains, pin "", note "Planned: self-hosted history via chained root kinographs and main-only compaction."})
